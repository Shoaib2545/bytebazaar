# ByteBazaar production environment.
#
#   cp .env.prod.example .env.prod
#   chmod 600 .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# NEVER commit .env.prod. Add it to .gitignore before you fill it in.
# Every variable without a default is marked REQUIRED — `docker compose config`
# fails if one is missing, which is deliberate.

# ---------------------------------------------------------------- domains ---
# REQUIRED. Real hostnames with A/AAAA records pointing at this host; Caddy
# requests a certificate for each one on first boot.
SITE_DOMAIN=bytebazaar.pk
API_DOMAIN=api.bytebazaar.pk
ADMIN_DOMAIN=admin.bytebazaar.pk

# REQUIRED. Address Let's Encrypt uses for expiry/problem notices.
ACME_EMAIL=ops@bytebazaar.pk

# REQUIRED. Space-separated CIDRs allowed to reach the admin panel.
# Use your office/VPN ranges. "0.0.0.0/0 ::/0" exposes it to the whole internet.
ADMIN_ALLOWED_CIDRS=203.0.113.0/24 198.51.100.7/32

# --------------------------------------------------------------- postgres ---
# REQUIRED. Not published to the host — reachable only inside the compose network.
POSTGRES_USER=bytebazaar
POSTGRES_DB=bytebazaar
# REQUIRED. Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_postgres

# ------------------------------------------------------------------ redis ---
# REQUIRED. Generate: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_redis

# ------------------------------------------------------------ meilisearch ---
# REQUIRED, minimum 16 bytes. Generate: openssl rand -base64 32
MEILI_MASTER_KEY=CHANGE_ME_meili
MEILI_INDEX_NAME=products

# -------------------------------------------------------------------- jwt ---
# REQUIRED. The value in appsettings.json is a PUBLISHED development key — with
# it, anyone can forge an admin token. Generate a fresh one:
#   openssl rand -base64 64
# Rotating this invalidates every issued access token (users re-login silently
# via their refresh cookie).
JWT_KEY=CHANGE_ME_jwt_at_least_64_random_characters_long_seriously_change_this
JWT_ISSUER=ByteBazaar
JWT_AUDIENCE=ByteBazaar.Clients
JWT_ACCESS_TOKEN_MINUTES=15

# ------------------------------------------------------------- storefront ---
# REQUIRED. Public HTTPS origins as the BROWSER sees them.
# PUBLIC_API_URL is baked into both frontend bundles at build time
# (NEXT_PUBLIC_API_URL and VITE_API_URL) — changing it needs a rebuild.
PUBLIC_API_URL=https://api.bytebazaar.pk
PUBLIC_SITE_URL=https://bytebazaar.pk

# REQUIRED. Hostnames allowed through the next/image optimizer. Must include
# every host that serves product/banner/category images or they render
# unoptimized. Comma-separated, no scheme.
NEXT_PUBLIC_IMAGE_HOSTS=bytebazaar.pk,cdn.bytebazaar.pk,placehold.co

# REQUIRED. Shared secret for POST /api/revalidate on the storefront.
# Generate: openssl rand -hex 32
REVALIDATE_SECRET=CHANGE_ME_revalidate

# Optional. How long the storefront caches the redirect map, in milliseconds.
REDIRECTS_TTL_MS=60000

# ---------------------------------------------------- analytics (optional) ---
# Leave NEXT_PUBLIC_POSTHOG_KEY unset to disable analytics entirely — with no
# key the instrumentation is a complete no-op (no requests, no localStorage).
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ----------------------------------------------------------------- backup ---
# Used by scripts/backup-postgres.sh when run against the prod stack.
PG_CONTAINER=bytebazaar-postgres-1
BACKUP_DIR=/var/backups/bytebazaar
RETENTION_DAYS=14
